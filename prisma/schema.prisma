generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Order {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  city      String
  address   String
  products  String
  total     Float
  status    String   @default("Нова")
  createdAt DateTime @default(now())
}